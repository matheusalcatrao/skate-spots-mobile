# Copy to `.env` and fill in from Supabase: Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# OAuth redirect (must match Supabase Dashboard → Authentication → URL Configuration EXACTLY)
#
# Default (when unset): `{expo.scheme}://auth/callback` e.g. stitch-mobile://auth/callback
# Add that exact string to Supabase redirect allowlist.
#
# Optional override — use when the default does not match your environment (e.g. Expo Go):
# EXPO_PUBLIC_OAUTH_REDIRECT_URL=exp://127.0.0.1:8081/--/auth/callback
#
# Google Cloud Console: only add Supabase’s HTTPS callback on the OAuth client (Web):
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
